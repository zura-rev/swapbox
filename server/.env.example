# PostgreSQL — Railway automatically sets this when you add PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# JWT
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production

# Client URL — leave empty in production (server serves React build)
CLIENT_URL=

# Cloudinary — image storage (get credentials from cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
