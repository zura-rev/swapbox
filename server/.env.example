# PostgreSQL — Railway automatically sets this when you add PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# JWT
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production

# Client URL — leave empty in production (server serves React build)
CLIENT_URL=

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
